<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Assistant" 
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title / ASCII Art Section -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Margin="0,0,0,10" Padding="10">
            <TextBlock x:Name="txtTitle" 
                       Text="CYBERSECURITY AWARENESS BOT"
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="#00B4D8"
                       HorizontalAlignment="Center"
                       FontFamily="Consolas"/>
        </Border>

        <!-- Chat History Display -->
        <Border Grid.Row="1" Background="#0F3460" CornerRadius="10" Padding="10">
            <RichTextBox x:Name="txtChatHistory" 
                         IsReadOnly="True"
                         Background="#0F3460"
                         Foreground="#E0E0E0"
                         FontFamily="Consolas"
                         FontSize="14"
                         BorderThickness="0">
                <RichTextBox.Resources>
                    <Style TargetType="{x:Type Paragraph}">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </Border>

        <!-- User Input Area -->
        <Grid Grid.Row="2" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtUserInput" 
                     Grid.Column="0"
                     Height="40"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     FontFamily="Consolas"
                     Background="#16213E"
                     Foreground="#E0E0E0"
                     BorderBrush="#00B4D8"
                     BorderThickness="2"
                     KeyDown="txtUserInput_KeyDown">
                <TextBox.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <Button x:Name="btnSend" 
                    Grid.Column="1"
                    Content="SEND"
                    Width="80"
                    Height="40"
                    Margin="5,0,5,0"
                    Background="#00B4D8"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="btnSend_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="btnExit" 
                    Grid.Column="2"
                    Content="EXIT"
                    Width="80"
                    Height="40"
                    Background="#E94560"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="btnExit_Click">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#16213E" CornerRadius="5" Padding="5">
            <TextBlock x:Name="txtStatus" 
                       Text="Ready to help you stay safe online!"
                       Foreground="#00B4D8"
                       FontSize="11"
                       FontFamily="Consolas"/>
        </Border>

    </Grid>
</Window>